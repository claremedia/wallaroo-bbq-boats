# WordPress Core
/wp-admin/
/wp-includes/
/wp-*.php
/xmlrpc.php
/readme.html
/license.txt

# Keep wp-config-sample.php but ignore actual config
wp-config.php

# Database dumps - contain credentials and user data
*.sql
*.sql.gz

# Uploads - user generated content
/wp-content/uploads/

# Breeze config - contains API tokens
/wp-content/breeze-config/

# Plugins - third-party managed separately; track only our custom plugins
/wp-content/plugins/*
!/wp-content/plugins/wbb-bookings/
!/wp-content/plugins/wbb-gift-vouchers/

# Cache and temp files
/wp-content/cache/
/wp-content/upgrade/
/wp-content/backup-db/
/wp-content/advanced-cache.php
/wp-content/wp-cache-config.php

# Server config - managed on host
.htaccess

# Node modules
node_modules/
**/node_modules/

# Build files
npm-debug.log
yarn-error.log

# OS files
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# IDE files
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# Environment files
.env
.env.local
.env.*.local

# Log files
*.log
error_log
debug.log

# Composer
/vendor/
composer.phar

# Local dev files
local-xdebuginfo.php
extract-docx*.ps1

# Object cache
/wp-content/object-cache.php

# Must-use plugins - third-party managed separately; track only our custom one
/wp-content/mu-plugins/*
!/wp-content/mu-plugins/wbb-business-manager.php
